# ─────────────────────────────────────────────
#  Panzer IT — Backend Environment Variables
#  Copy this file to .env and fill in all values
# ─────────────────────────────────────────────

# Server
PORT=5000
NODE_ENV=development          # development | production

# ─── MongoDB ──────────────────────────────────
MONGO_URI=mongodb+srv://<user>:<pass>@cluster.mongodb.net/panzerit

# ─── JWT ──────────────────────────────────────
JWT_SECRET=replace_with_a_long_random_secret_min_32_chars
JWT_EXPIRES_IN=7d
JWT_COOKIE_EXPIRES_IN=7       # days — for httpOnly cookie (admin panel)

# ─── Bcrypt ───────────────────────────────────
BCRYPT_SALT_ROUNDS=12

# ─── Email (Nodemailer / SMTP) ────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false             # true for port 465, false for 587
SMTP_USER=your@gmail.com
SMTP_PASS=your_app_password   # Gmail: use an App Password, not your account password
SMTP_FROM_NAME=Panzer IT
SMTP_FROM_EMAIL=no-reply@panzerit.com

# Lead notification — who gets emailed on new contact form submission
LEAD_NOTIFY_EMAIL=admin@panzerit.com

# ─── File Uploads ─────────────────────────────
UPLOAD_DIR=uploads/
MAX_FILE_SIZE=10mb            # applies to single file upload
ALLOWED_IMAGE_TYPES=image/jpeg,image/png,image/webp,image/svg+xml
ALLOWED_DOC_TYPES=application/pdf

# ─── CORS origins ─────────────────────────────
FRONTEND_URL=http://localhost:5173
ADMIN_URL=http://localhost:5174

# ─── Rate limits (optional overrides) ─────────
# RATE_LIMIT_WINDOW_MS=900000   # 15 min in ms
# RATE_LIMIT_MAX=200
# AUTH_RATE_LIMIT_MAX=20        # stricter limit for /auth routes
